    },
    {
      "type": "timeseries",
      "title": "HTTP Timing Phases (Avg)",
      "description": "Breakdown: Blocked → Connecting → TLS → Sending → Waiting (TTFB) → Receiving",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "k6_http_req_blocked_avg", "legendFormat": "Blocked", "refId": "A" },
