{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "type": "row",
      "title": "📊 Performance Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Performance Overview (VUs / Avg req/s / Avg Duration / Avg P95)",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "k6_vus", "legendFormat": "VUs", "refId": "A" },
        { "expr": "sum(rate(k6_http_reqs_total[1m]))", "legendFormat": "Avg req/s", "refId": "B" },
        { "expr": "sum(rate(k6_http_reqs_total[1m])) * avg(k6_http_req_failed_rate)", "legendFormat": "Failure req/s", "refId": "B2" },
        { "expr": "avg(k6_http_req_duration_avg)", "legendFormat": "Avg Duration (ms)", "refId": "C" },
        { "expr": "avg(k6_http_req_duration_p95)", "legendFormat": "Avg P95 (ms)", "refId": "D" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "pointSize": 3, "spanNulls": true, "axisSoftMin": 0 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "VUs" }, "properties": [{ "id": "custom.axisPlacement", "value": "right" }, { "id": "unit", "value": "short" }] },
          { "matcher": { "id": "byName", "options": "Avg req/s" }, "properties": [{ "id": "unit", "value": "reqps" }] },
          { "matcher": { "id": "byName", "options": "Failure req/s" }, "properties": [{ "id": "unit", "value": "reqps" }, { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }] },
          { "matcher": { "id": "byName", "options": "Avg Duration (ms)" }, "properties": [{ "id": "unit", "value": "ms" }] },
          { "matcher": { "id": "byName", "options": "Avg P95 (ms)" }, "properties": [{ "id": "unit", "value": "ms" }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 }
    },
    {
      "type": "stat",
      "title": "Active VUs",
      "datasource": "Prometheus",
      "targets": [{ "expr": "k6_vus", "legendFormat": "VUs" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 900 }] } } },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 9 }
    },
    {
      "type": "stat",
      "title": "Max VUs",
      "datasource": "Prometheus",
      "targets": [{ "expr": "k6_vus_max", "legendFormat": "Max VUs" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 9 }
    },
    {
      "type": "stat",
      "title": "Request Rate",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(rate(k6_http_reqs_total[30s]))", "legendFormat": "req/s" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 9 }
    },
    {
      "type": "stat",
      "title": "Avg Response",
      "datasource": "Prometheus",
      "targets": [{ "expr": "avg(k6_http_req_duration_avg)", "legendFormat": "avg" }],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 2000 }] } } },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 9 }
    },
    {
      "type": "stat",
      "title": "Median Response",
      "datasource": "Prometheus",
      "targets": [{ "expr": "avg(k6_http_req_duration_med)", "legendFormat": "med" }],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 2000 }] } } },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 9 }
    },
    {
      "type": "stat",
      "title": "P90 Latency",
      "datasource": "Prometheus",
      "targets": [{ "expr": "avg(k6_http_req_duration_p90)", "legendFormat": "p90" }],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2000 }, { "color": "red", "value": 5000 }] } } },
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 9 }
    },
    {
      "type": "stat",
      "title": "P95 Latency",
      "datasource": "Prometheus",
      "targets": [{ "expr": "avg(k6_http_req_duration_p95)", "legendFormat": "p95" }],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2000 }, { "color": "red", "value": 5000 }] } } },
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 9 }
    },
    {
      "type": "stat",
      "title": "P99 Latency",
      "datasource": "Prometheus",
      "targets": [{ "expr": "avg(k6_http_req_duration_p99)", "legendFormat": "p99" }],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3000 }, { "color": "red", "value": 8000 }] } } },
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 9 }
    },
    {
      "type": "stat",
      "title": "Failure Rate",
      "datasource": "Prometheus",
      "targets": [{ "expr": "avg(k6_http_req_failed_rate)", "legendFormat": "fail %" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 13 }
    },
    {
      "type": "stat",
      "title": "Checks Pass Rate",
      "datasource": "Prometheus",
      "targets": [{ "expr": "avg(k6_checks_rate)", "legendFormat": "pass %" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.9 }, { "color": "green", "value": 0.99 }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 13 }
    },
    {
      "type": "stat",
      "title": "Total Requests",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(increase(k6_http_reqs_total[5m]))", "legendFormat": "total" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 13 }
    },
    {
      "type": "stat",
      "title": "Data Received",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(k6_data_received_total)", "legendFormat": "received" }],
      "fieldConfig": { "defaults": { "unit": "decbytes", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": null }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 13 }
    },
    {
      "type": "stat",
      "title": "Data Sent",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(k6_data_sent_total)", "legendFormat": "sent" }],
      "fieldConfig": { "defaults": { "unit": "decbytes", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "orange", "value": null }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 13 }
    },

    {
