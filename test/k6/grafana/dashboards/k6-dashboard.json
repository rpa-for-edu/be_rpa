      "targets": [
        { "expr": "k6_get_user_me_duration_min", "legendFormat": "/users/me min", "refId": "A1" },
        { "expr": "k6_get_user_me_duration_max", "legendFormat": "/users/me max", "refId": "A2" },
        { "expr": "k6_get_connection_duration_min", "legendFormat": "/connection min", "refId": "B1" },
        { "expr": "k6_get_connection_duration_max", "legendFormat": "/connection max", "refId": "B2" },
        { "expr": "k6_get_workspace_duration_min", "legendFormat": "/workspace min", "refId": "C1" },
