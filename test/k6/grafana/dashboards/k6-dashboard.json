        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 25, "gradientMode": "scheme", "spanNulls": true }, "color": { "fixedColor": "blue", "mode": "fixed" } }
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "min", "max", "lastNotNull"] } },
